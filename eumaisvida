<script>
const obs = new IntersectionObserver((entries) => { entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); } }); }, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
setTimeout(() => document.querySelectorAll('.hero .reveal').forEach(el => el.classList.add('visible')), 80);
function submitForm(e) { e.preventDefault(); const btn = e.target.querySelector('button'); btn.textContent = '✓ Recebemos seu contato!'; btn.style.background = '#7DC0E0'; btn.disabled = true; e.target.reset(); setTimeout(() => { btn.textContent = 'Quero o diagnóstico'; btn.style.background = ''; btn.disabled = false; }, 5000); }
